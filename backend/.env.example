# ============================================================
#  CF Pilot — Environment Variables Reference
#  Copy this file to .env and fill in the values.
#  NEVER commit your actual .env file.
# ============================================================

# ── Application ──────────────────────────────────────────────
ENV=development            # development | production | test
DB_PATH=/app/data/cfpilot.db
WEB_CONCURRENCY=2          # Number of uvicorn worker processes

# ── CORS / Origins ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Security ─────────────────────────────────────────────────
DB_ENCRYPTION_KEY=         # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=                # Django-style secret key for JWT / session signing

# ── LLM / AI ─────────────────────────────────────────────────
OPENROUTER_API_KEY=        # Get from https://openrouter.ai/keys

# ── Salesforce ───────────────────────────────────────────────
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_DOMAIN=login            # 'login' for production, 'test' for sandbox
